{
  "compilerOptions": {
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "resolvePackageJsonExports": true,
    "esModuleInterop": true,
    "isolatedModules": true,
    "declaration": true,
    "removeComments": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "target": "ES2023",
    "sourceMap": true,
    "outDir": "./dist",
    "baseUrl": "./",
    "incremental": true,
    "skipLibCheck": true,
    "strictNullChecks": true,
    "forceConsistentCasingInFileNames": true,
    "noImplicitAny": false,
    "strictBindCallApply": false,
    "noFallthroughCasesInSwitch": false,
    "paths": {
      "@geo/common": [
        "libs/common/src"
      ],
      "@geo/common/*": [
        "libs/common/src/*"
      ],
      "@geo/config": [
        "libs/config/src"
      ],
      "@geo/config/*": [
        "libs/config/src/*"
      ],
      "@geo/contracts": [
        "libs/contracts/src"
      ],
      "@geo/contracts/*": [
        "libs/contracts/src/*"
      ],
      "@geo/logger": [
        "libs/logger/src"
      ],
      "@geo/logger/*": [
        "libs/logger/src/*"
      ]
    }
  }
}